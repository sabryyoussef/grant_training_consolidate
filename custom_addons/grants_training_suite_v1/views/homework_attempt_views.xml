<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        
        <!-- Homework Attempt Form View -->
        <record id="view_gr_homework_attempt_form" model="ir.ui.view">
            <field name="name">gr.homework.attempt.form</field>
            <field name="model">gr.homework.attempt</field>
            <field name="arch" type="xml">
                <form string="Homework Attempt">
                    <header>
                        <!-- Primary Action Buttons -->
                        <button name="action_submit" string="Submit" type="object" class="btn-primary" 
                                invisible="state != 'draft'"/>
                        <button name="action_start_review" string="Start Review" type="object" class="btn-primary" 
                                invisible="state != 'submitted'"/>
                        <button name="action_grade" string="Grade" type="object" class="btn-success" 
                                invisible="state != 'under_review'"/>
                        <button name="action_return" string="Return to Student" type="object" class="btn-warning" 
                                invisible="state != 'graded'"/>
                        <button name="action_resubmit" string="Resubmit" type="object" class="btn-primary" 
                                invisible="state != 'returned'"/>
                        <button name="action_reset" string="Reset" type="object" class="btn-secondary" 
                                invisible="state in ['draft', 'resubmitted']"/>
                        
                        <!-- Quick Transition Buttons -->
                        <button name="action_transition_to_submitted" string="→ Submit" type="object" class="btn-outline-primary" 
                                invisible="state != 'draft'" title="Quick transition to Submitted"/>
                        <button name="action_transition_to_under_review" string="→ Review" type="object" class="btn-outline-primary" 
                                invisible="state != 'submitted'" title="Quick transition to Under Review"/>
                        <button name="action_transition_to_graded" string="→ Grade" type="object" class="btn-outline-success" 
                                invisible="state != 'under_review'" title="Quick transition to Graded"/>
                        <button name="action_transition_to_returned" string="→ Return" type="object" class="btn-outline-warning" 
                                invisible="state != 'graded'" title="Quick transition to Returned"/>
                        <button name="action_transition_to_resubmitted" string="→ Resubmit" type="object" class="btn-outline-primary" 
                                invisible="state != 'returned'" title="Quick transition to Resubmitted"/>
                        <button name="action_transition_to_draft" string="→ Draft" type="object" class="btn-outline-secondary" 
                                invisible="state in ['draft', 'resubmitted']" title="Quick transition to Draft"/>
                        
                        <!-- Auto-save Button -->
                        <button name="auto_save_content" string="Auto-save" type="object" class="btn-outline-info" 
                                invisible="state != 'draft'" title="Auto-save current content"/>
                        
                        <field name="state" widget="statusbar" statusbar_visible="draft,submitted,under_review,graded,returned"/>
                    </header>
                    <sheet>
                        <div class="oe_button_box" name="button_box">
                            <div class="oe_stat_button" icon="fa-percentage">
                                <field name="grade_percentage" widget="statinfo" string="Grade %"/>
                            </div>
                            <div class="oe_stat_button" icon="fa-clock-o" 
                                 invisible="is_late == False">
                                <field name="days_late" widget="statinfo" string="Days Late"/>
                            </div>
                            <div class="oe_stat_button" icon="fa-file-text-o" 
                                 invisible="submission_file == False">
                                <field name="submission_file" widget="statinfo" string="File"/>
                            </div>
                        </div>
                        
                        <div class="oe_title">
                            <h1>
                                <field name="name" readonly="1"/>
                            </h1>
                        </div>
                        
                        <group>
                            <group string="Homework Details">
                                <field name="student_id" required="1"/>
                                <field name="agent_id" required="1"/>
                                <field name="homework_title" required="1"/>
                                <field name="homework_type"/>
                                <field name="due_date"/>
                                <field name="state"/>
                            </group>
                            <group string="Submission Information">
                                <field name="submission_date" readonly="1"/>
                                <field name="is_late" readonly="1"/>
                                <field name="days_late" readonly="1"/>
                                <field name="grade" invisible="state not in ['under_review', 'graded', 'returned']"/>
                                <field name="max_grade" invisible="state not in ['under_review', 'graded', 'returned']"/>
                                <field name="grade_percentage" readonly="1" invisible="state not in ['graded', 'returned']"/>
                                <field name="grade_letter" readonly="1" invisible="state not in ['graded', 'returned']"/>
                            </group>
                        </group>
                        
                        <group>
                            <field name="homework_description" readonly="1"/>
                        </group>
                        
                        <group>
                            <group string="Submission Content">
                                <field name="submission_content" placeholder="Enter your homework content here..." 
                                       options="{'auto_save': true}" 
                                       invisible="state in ['graded', 'returned']"/>
                                <field name="submission_file" filename="submission_filename" 
                                       invisible="state in ['graded', 'returned']"/>
                                <field name="submission_filename" readonly="1"/>
                                <div invisible="state != 'draft'" class="alert alert-info">
                                    <strong>Auto-save:</strong> Your content is automatically saved as you type.
                                </div>
                            </group>
                            <group string="Review Information" invisible="state not in ['under_review', 'graded', 'returned']">
                                <field name="review_date" readonly="1"/>
                                <field name="reviewed_by_id" readonly="1"/>
                                <field name="feedback"/>
                            </group>
                        </group>
                        
                        <notebook>
                            <page string="Submission" invisible="state == 'draft'">
                                <group>
                                    <group>
                                        <field name="submission_date" readonly="1"/>
                                        <field name="is_late" readonly="1"/>
                                        <field name="days_late" readonly="1"/>
                                    </group>
                                    <group>
                                        <field name="submission_content" readonly="1"/>
                                    </group>
                                </group>
                                <group string="Submitted File" invisible="submission_file == False">
                                    <field name="submission_file" widget="binary" filename="submission_filename" readonly="1"/>
                                </group>
                            </page>
                            
                            <page string="Grading" invisible="state not in ['graded', 'returned']">
                                <group>
                                    <group>
                                        <field name="grade" readonly="1"/>
                                        <field name="max_grade" readonly="1"/>
                                        <field name="grade_percentage" readonly="1"/>
                                        <field name="grade_letter" readonly="1"/>
                                    </group>
                                    <group>
                                        <field name="review_date" readonly="1"/>
                                        <field name="reviewed_by_id" readonly="1"/>
                                    </group>
                                </group>
                                <group>
                                    <field name="feedback" readonly="1"/>
                                </group>
                            </page>
                            
                            <page string="Instructions">
                                <group>
                                    <field name="homework_description" readonly="1"/>
                                </group>
                            </page>
                        </notebook>
                    </sheet>
                </form>
            </field>
        </record>

        <!-- Homework Attempt List View -->
        <record id="view_gr_homework_attempt_list" model="ir.ui.view">
            <field name="name">gr.homework.attempt.list</field>
            <field name="model">gr.homework.attempt</field>
            <field name="arch" type="xml">
                <list string="Homework Attempts" default_order="submission_date desc">
                    <field name="name"/>
                    <field name="student_id"/>
                    <field name="agent_id"/>
                    <field name="homework_title"/>
                    <field name="homework_type"/>
                    <field name="due_date"/>
                    <field name="submission_date"/>
                    <field name="is_late"/>
                    <field name="grade_percentage"/>
                    <field name="state" widget="badge" decoration-success="state == 'returned'" 
                           decoration-warning="state == 'graded'" decoration-info="state == 'submitted'" 
                           decoration-danger="state == 'draft'"/>
                </list>
            </field>
        </record>

        <!-- Homework Attempt Kanban View -->
        <record id="view_gr_homework_attempt_kanban" model="ir.ui.view">
            <field name="name">gr.homework.attempt.kanban</field>
            <field name="model">gr.homework.attempt</field>
            <field name="arch" type="xml">
                <kanban default_group_by="state" class="o_kanban_small_column">
                    <field name="name"/>
                    <field name="state"/>
                    <field name="student_id"/>
                    <field name="agent_id"/>
                    <field name="homework_title"/>
                    <field name="homework_type"/>
                    <field name="due_date"/>
                    <field name="submission_date"/>
                    <field name="is_late"/>
                    <field name="grade_percentage"/>
                    <templates>
                        <t t-name="kanban-box">
                            <div class="oe_kanban_card oe_kanban_global_click">
                                <div class="oe_kanban_content">
                                    <div class="o_kanban_record_top">
                                        <div class="o_kanban_record_headings">
                                            <strong class="o_kanban_record_title">
                                                <field name="name"/>
                                            </strong>
                                        </div>
                                        <div class="o_kanban_record_subtitle">
                                            <field name="homework_title"/>
                                        </div>
                                    </div>
                                    <div class="o_kanban_record_body">
                                        <div class="o_kanban_record_details">
                                            <div class="o_kanban_record_bottom">
                                                <div class="oe_kanban_bottom_left">
                                                    <span>Student: <field name="student_id"/></span>
                                                </div>
                                                <div class="oe_kanban_bottom_right">
                                                    <span>Grade: <field name="grade_percentage"/>%</span>
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </t>
                    </templates>
                </kanban>
            </field>
        </record>

        <!-- Homework Attempt Search View -->
        <record id="view_gr_homework_attempt_search" model="ir.ui.view">
            <field name="name">gr.homework.attempt.search</field>
            <field name="model">gr.homework.attempt</field>
            <field name="arch" type="xml">
                <search string="Search Homework Attempts">
                    <field name="name"/>
                    <field name="student_id"/>
                    <field name="agent_id"/>
                    <field name="homework_title"/>
                    <field name="homework_type"/>
                    <separator/>
                    <filter string="Draft" name="draft" domain="[('state', '=', 'draft')]"/>
                    <filter string="Submitted" name="submitted" domain="[('state', '=', 'submitted')]"/>
                    <filter string="Under Review" name="under_review" domain="[('state', '=', 'under_review')]"/>
                    <filter string="Graded" name="graded" domain="[('state', '=', 'graded')]"/>
                    <filter string="Returned" name="returned" domain="[('state', '=', 'returned')]"/>
                    <filter string="Resubmitted" name="resubmitted" domain="[('state', '=', 'resubmitted')]"/>
                    <separator/>
                    <filter string="Late Submissions" name="late" domain="[('is_late', '=', True)]"/>
                    <filter string="Overdue" name="overdue" domain="[('due_date', '&lt;', context_today().strftime('%Y-%m-%d')), ('state', 'in', ['draft', 'submitted'])]"/>
                    <filter string="High Grades" name="high_grades" domain="[('grade_percentage', '&gt;=', 90)]"/>
                    <separator/>
                    <filter string="This Week" name="this_week" domain="[('submission_date', '>=', (context_today() - relativedelta(weeks=1)).strftime('%Y-%m-%d'))]"/>
                    <filter string="This Month" name="this_month" domain="[('submission_date', '>=', (context_today() - relativedelta(months=1)).strftime('%Y-%m-01'))]"/>
                    <group expand="0" string="Group By">
                        <filter string="Status" name="group_state" context="{'group_by': 'state'}"/>
                        <filter string="Student" name="group_student" context="{'group_by': 'student_id'}"/>
                        <filter string="Agent" name="group_agent" context="{'group_by': 'agent_id'}"/>
                        <filter string="Homework Type" name="group_homework_type" context="{'group_by': 'homework_type'}"/>
                        <filter string="Submission Date" name="group_submission_date" context="{'group_by': 'submission_date'}"/>
                    </group>
                </search>
            </field>
        </record>

        <!-- Homework Attempt Action -->
        <record id="action_gr_homework_attempt" model="ir.actions.act_window">
            <field name="name">Homework Attempts</field>
            <field name="res_model">gr.homework.attempt</field>
            <field name="view_mode">kanban,list,form</field>
            <field name="context">{'search_default_this_week': 1}</field>
            <field name="help" type="html">
                <p class="o_view_nocontent_smiling_face">
                    Create your first homework attempt!
                </p>
                <p>
                    Homework attempts track student submissions, grading, and feedback,
                    including file uploads, late submissions, and grade management.
                </p>
            </field>
        </record>

    </data>
</odoo>
